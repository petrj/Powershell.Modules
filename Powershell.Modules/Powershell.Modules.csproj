<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Powershell.Modules</RootNamespace>
    <RepositoryUrl>https://github.com/petrj/NugetLibrary</RepositoryUrl>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <Title>Powershell modules library</Title>
    <Description>Powershell modules library</Description>
    <Authors>Petr Janousek</Authors>
    <AssemblyVersion>1.0.0.0</AssemblyVersion>
    <FileVersion>1.0.0.0</FileVersion>
  </PropertyGroup>
  <ItemGroup>
    <!-- <PackageReference Include="LoggerService" /--> 
  </ItemGroup>
  <ItemGroup>
    <Content Include="BuildModule\**\*;LinuxPSTools\**\*">
      <Pack>true</Pack>
      <PackagePath>Powershell.Modules\%(Identity)</PackagePath>      
    </Content>
  </ItemGroup>
</Project>